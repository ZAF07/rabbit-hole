# The one Postgres database, selected by connection config alone: Docker (local)
# <-> Supabase (scale) is a DSN swap, never a code change. Both subsystems read
# this same variable — generation writes the Content Graph tables, consumption
# owns the user / session / path tables, in one database (ADR 0018).
DATABASE_URL=postgresql://rabbit:rabbit@localhost:5433/rabbithole

# Used by the content-graph contract-test suite's Postgres run
# (docker compose up -d postgres). Separate throwaway databases keep the test
# suites isolated; they are test infra, not the production topology.
CONTENT_GRAPH_TEST_DSN=postgresql://rabbit:rabbit@localhost:5433/content_graph_test

# Used by the consumption contract-test suite's Postgres run.
CONSUMPTION_TEST_DSN=postgresql://rabbit:rabbit@localhost:5433/consumption_test

# The HTTP API layer (one FastAPI deployable — reader + admin routers).
# The HMAC key the anonymous reader-identity token is signed with. Set per
# deployment; a leak lets a holder forge reader identities.
API_IDENTITY_SECRET=dev-only-change-me

# The operator secret that gates the admin generation trigger, distinct from
# reader identity. Leave unset to keep the admin trigger disabled.
API_ADMIN_TOKEN=dev-only-operator-secret

# The production LLM adapter (ADR 0016). Selecting the provider and turning on
# real generation is deployment config, never a code change. Leave LLM_PROVIDER
# unset to keep the admin generation trigger dormant (no real model wired).
# A tier is a (model, temperature) pair chosen per request purpose:
#   precise  — DeepSeek V4 Flash at near-0, for structural/judging purposes
#   creative — DeepSeek V4 Pro at a higher temperature, for prose purposes
LLM_PROVIDER=deepseek
LLM_API_KEY=dev-only-deepseek-key
LLM_MODEL_PRECISE=deepseek-v4-flash
LLM_MODEL_CREATIVE=deepseek-v4-pro
LLM_TEMPERATURE_PRECISE=0.0
LLM_TEMPERATURE_CREATIVE=1.0
