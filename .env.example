# The Content Graph store is selected by connection config alone:
# Docker (local) <-> Supabase (scale) is a DSN swap, never a code change.
CONTENT_GRAPH_DSN=postgresql://rabbit:rabbit@localhost:5433/content_graph

# Used by the contract-test suite's Postgres run (docker compose up -d postgres).
CONTENT_GRAPH_TEST_DSN=postgresql://rabbit:rabbit@localhost:5433/content_graph_test

# The consumption store — the reader's own user / session / path tables.
# A separate store from the Content Graph (which the reader only reads);
# Docker (local) <-> Supabase (scale) is the same DSN swap, never a code change.
CONSUMPTION_DSN=postgresql://rabbit:rabbit@localhost:5433/consumption

# Used by the consumption contract-test suite's Postgres run.
CONSUMPTION_TEST_DSN=postgresql://rabbit:rabbit@localhost:5433/consumption_test

# The HTTP API layer (one FastAPI deployable — reader + admin routers).
# The HMAC key the anonymous reader-identity token is signed with. Set per
# deployment; a leak lets a holder forge reader identities.
API_IDENTITY_SECRET=dev-only-change-me

# The operator secret that gates the admin generation trigger, distinct from
# reader identity. Leave unset to keep the admin trigger disabled.
API_ADMIN_TOKEN=dev-only-operator-secret
